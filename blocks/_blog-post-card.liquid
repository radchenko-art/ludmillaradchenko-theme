
{%- assign block_settings = block.settings -%}

<section class="blog-post-card blog-post-card--donor{% unless article.image %} blog-post-card--no-image{% endunless %}" style="--text-align: {{ block_settings.alignment }}">
  <div class="blog-post-card__row">
    {% if article.image %}
      <div class="blog-post-card__col blog-post-card__col--image">
        {% content_for 'block', id: 'image', type: '_blog-post-image', article: article %}
      </div>
    {% endif %}
    <div class="blog-post-card__col blog-post-card__col--content">
      <div class="blog-post-card__content">
        <h3 class="blog-post-card__title">
          <a href="{{ article.url }}" data-testid="blog-post-link">{{ article.title }}</a>
        </h3>
        {% content_for 'block',
          id: 'blog-post-details',
          type: '_blog-post-info-text',
          alignment: block_settings.alignment,
          article: article
        %}
        <div class="blog-post-card__action">
          <a href="{{ article.url }}" class="blog-post-card__view-btn" role="button">{{ 'blogs.view_now' | t }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .blog-post-card--donor {
    width: 100%;
  }

  .blog-post-card--donor .blog-post-card__row {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 0;
    max-width: 1140px;
    margin: 0 auto;
  }

  .blog-post-card--donor .blog-post-card__col {
    flex: 1 1 50%;
    min-width: 0;
  }

  .blog-post-card--donor .blog-post-card__col--image .blog-post-card__image-container {
    width: 100%;
  }

  .blog-post-card--donor .blog-post-card__col--image .blog-post-card__image {
    width: 100%;
    height: auto;
    max-height: none;
  }

  .blog-post-card--donor .blog-post-card__col--content {
    flex: 1 1 50%;
    min-height: 100%;
    padding: 0% 6% 0% 6%;
    text-align: var(--text-align);
    background-color: #fcfcfc;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .blog-post-card--donor .blog-post-card__title {
    color: #ff0000;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 30px;
    text-transform: uppercase;
  }

  .blog-post-card--donor .blog-post-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .blog-post-card--donor .blog-post-card__title a:hover {
    color: #ff0000;
    opacity: 0.9;
  }

  .blog-post-card--donor .blog-post-details {
    font-family: var(--font-accent-second--family);
    color: #7a7a7a;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .blog-post-card--donor .blog-post-card__view-btn {
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background-color: #ce2d2a;
    border-radius: 50px;
    padding: 15px 50px;
    border: 3px solid #ce2d2a;
    text-decoration: none;
    text-align: center;
    transition: 0.5s;
    display: inline-block;
    line-height: 1;
    color: #ffffff;
  }

  .blog-post-card--donor .blog-post-card__view-btn:hover {
    color: #ce2d2a;
    background-color: transparent;
    border: 3px solid #ce2d2a;
  }

  .blog-post-card--donor.blog-post-card--no-image .blog-post-card__col--content {
    flex: 1 1 100%;
  }

  @media screen and (max-width: 749px) {
    .blog-post-card--donor .blog-post-card__row {
      flex-direction: column;
    }

    .blog-post-card--donor .blog-post-card__col {
      flex: 1 1 100%;
    }

    .blog-post-card--donor .blog-post-card__col--content {
      padding: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_post",
  "settings": [
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    }
  ]
}
{% endschema %}
