

{% capture submit_button %}
  {% content_for 'block', type: 'contact-form-submit-button', id: 'submit-button' %}
{% endcapture %}

<div
  class="
    contact-form
    spacing-style size-style
    {% if block.settings.inherit_color_scheme == false %}color-{{ block.settings.color_scheme }}{% endif %}
  "
  style="
    {% render 'spacing-style', settings: block.settings %}
    {% render 'size-style', settings: block.settings %}
  "
  {{ block.shopify_attributes }}
>
  {%- liquid
    assign modal_mode = block.settings.modal_mode
    assign show_out_of_stock = block.settings.show_out_of_stock
    assign is_out_of_stock = false

    if show_out_of_stock and product
      unless product.available
        assign is_out_of_stock = true
      endunless
    endif
  -%}

  {%- if is_out_of_stock -%}
    <div class="contact-form__stock-label">OUT-OF-STOCK</div>
  {%- endif -%}

  {% capture contact_form_markup %}
    {% assign form_id = block.id | default: section.id | prepend: 'ContactForm-' %}
    {%- form 'contact', id: form_id, class: 'contact-form__form' -%}
      <input
        name="contact[id]"
        type="hidden"
        value="{{ form_id }}"
      >

      {%- if form.errors and form.id == form_id -%}
        <div
          class="contact-form__error"
          tabindex="-1"
          autofocus
        >
          {{- 'icon-error.svg' | inline_asset_content -}}

          {{- form.errors.translated_fields.email | capitalize }}
          {{ form.errors.messages.email -}}
        </div>
      {%- endif -%}

      {%- if form.posted_successfully? and form.id == form_id -%}
        <div
          class="contact-form__success"
          tabindex="-1"
          autofocus
        >
          {{- 'icon-checkmark.svg' | inline_asset_content -}}
          {{- 'blocks.contact_form.post_success' | t -}}
        </div>
      {%- endif -%}

      <div class="contact-form__field">
        <label
          class="contact-form__label"
          for="ContactForm-name"
        >
          Name <span aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="ContactForm-name"
          class="contact-form__input"
          autocomplete="name"
          name="contact[name]"
          value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          required
        >
      </div>

      <div class="contact-form__field">
        <label
          class="contact-form__label"
          for="ContactForm-whatsapp"
        >
          WhatsApp
        </label>
        <div class="contact-form__whatsapp-group">
          <label
            class="visually-hidden"
            for="ContactForm-whatsapp-country"
          >
            WhatsApp country code
          </label>
          <select
            id="ContactForm-whatsapp-country"
            class="contact-form__input contact-form__input--country"
            name="contact[WhatsApp country]"
            autocomplete="country"
          >
            <option value="+971">🇦🇪 +971</option>
            <option value="+1">🇺🇸 +1</option>
            <option value="+44">🇬🇧 +44</option>
            <option value="+49">🇩🇪 +49</option>
            <option value="+33">🇫🇷 +33</option>
            <option value="+34">🇪🇸 +34</option>
            <option value="+39">🇮🇹 +39</option>
          </select>
          <input
            type="tel"
            id="ContactForm-whatsapp"
            class="contact-form__input"
            autocomplete="tel"
            name="contact[WhatsApp]"
            pattern="[0-9\\-\\+\\s\\(\\)]*"
            placeholder="Phone number"
          >
        </div>
      </div>

      <div class="contact-form__field">
        <label
          class="contact-form__label"
          for="ContactForm-email"
        >
          Email <span aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="ContactForm-email"
          class="contact-form__input"
          autocomplete="email"
          name="contact[email]"
          spellcheck="false"
          autocapitalize="off"
          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          aria-required="true"
          required
          {% if form.errors contains 'email' and form.id == form_id %}
            aria-invalid="true"
            aria-describedby="ContactForm-email-error"
          {% endif %}
        >
      </div>

      <fieldset class="contact-form__fieldset">
        <legend class="contact-form__legend">I'm interested in: <span aria-hidden="true">*</span></legend>
        <div class="contact-form__radio-list">
          <label class="contact-form__radio-option" for="Interest-original">
            <input
              id="Interest-original"
              type="radio"
              name="contact[I'm interested in]"
              value="Original artwork/uniquepiece"
              required
            >
            <span>Original artwork/uniquepiece</span>
          </label>
          <label class="contact-form__radio-option" for="Interest-multiple">
            <input
              id="Interest-multiple"
              type="radio"
              name="contact[I'm interested in]"
              value="Multiple Art- limited edition prints"
            >
            <span>Multiple Art- limited edition prints</span>
          </label>
          <label class="contact-form__radio-option" for="Interest-commission">
            <input
              id="Interest-commission"
              type="radio"
              name="contact[I'm interested in]"
              value="Сommission /personalized order"
            >
            <span>Сommission /personalized order</span>
          </label>
          <label class="contact-form__radio-option" for="Interest-brand">
            <input
              id="Interest-brand"
              type="radio"
              name="contact[I'm interested in]"
              value="Brand Collaboration"
            >
            <span>Brand Collaboration</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="contact-form__fieldset">
        <legend class="contact-form__legend">Select your budget range <span aria-hidden="true">*</span></legend>
        <div class="contact-form__radio-list">
          <label class="contact-form__radio-option" for="Budget-under-2000">
            <input
              id="Budget-under-2000"
              type="radio"
              name="contact[Select your budget range]"
              value="Under €2,000"
              required
            >
            <span>Under €2,000</span>
          </label>
          <label class="contact-form__radio-option" for="Budget-2000-5000">
            <input
              id="Budget-2000-5000"
              type="radio"
              name="contact[Select your budget range]"
              value="€2,000 – €5,000"
            >
            <span>€2,000 – €5,000</span>
          </label>
          <label class="contact-form__radio-option" for="Budget-5000-10000">
            <input
              id="Budget-5000-10000"
              type="radio"
              name="contact[Select your budget range]"
              value="€5,000 – €10,000"
            >
            <span>€5,000 – €10,000</span>
          </label>
          <label class="contact-form__radio-option" for="Budget-10000-plus">
            <input
              id="Budget-10000-plus"
              type="radio"
              name="contact[Select your budget range]"
              value="€10,000+"
            >
            <span>€10,000+</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="contact-form__fieldset">
        <legend class="contact-form__legend">Space Type <span aria-hidden="true">*</span></legend>
        <div class="contact-form__radio-list">
          <label class="contact-form__radio-option" for="Space-home">
            <input
              id="Space-home"
              type="radio"
              name="contact[Space Type]"
              value="Home"
              required
            >
            <span>Home</span>
          </label>
          <label class="contact-form__radio-option" for="Space-office">
            <input
              id="Space-office"
              type="radio"
              name="contact[Space Type]"
              value="Office"
            >
            <span>Office</span>
          </label>
          <label class="contact-form__radio-option" for="Space-hotel">
            <input
              id="Space-hotel"
              type="radio"
              name="contact[Space Type]"
              value="Hotel / Restaurant"
            >
            <span>Hotel / Restaurant</span>
          </label>
          <label class="contact-form__radio-option" for="Space-other">
            <input
              id="Space-other"
              type="radio"
              name="contact[Space Type]"
              value="Other"
            >
            <span>Other</span>
          </label>
        </div>
      </fieldset>

      <div class="contact-form__field">
        <label
          class="contact-form__label"
          for="ContactForm-location"
        >
          Location <span aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="ContactForm-location"
          class="contact-form__input"
          name="contact[Location]"
          placeholder="Country / City"
          required
        >
      </div>

      <div class="contact-form__field">
        <label
          class="contact-form__label"
          for="ContactForm-preferred-size"
        >
          Preferred Size <span aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="ContactForm-preferred-size"
          class="contact-form__input"
          name="contact[Preferred Size]"
          placeholder="e.g., 100x100 cm or Custom"
          required
        >
      </div>

      <div class="contact-form__field">
        <label
          class="contact-form__label"
          for="ContactForm-body"
        >
          Notes / Details <span aria-hidden="true">*</span>
        </label>
        <textarea
          rows="10"
          id="ContactForm-body"
          class="contact-form__input contact-form__input--textarea"
          name="contact[body]"
          placeholder="Describe your idea, colors, or theme..."
          required
        >
          {{- form.body -}}
        </textarea>
      </div>

      {{ submit_button }}
    {%- endform -%}
  {% endcapture %}

  {%- if modal_mode -%}
    {%- assign dialog_id = 'ContactFormDialog-' | append: block.id -%}
    <dialog-component>
      <button
        type="button"
        class="button contact-form__open-button"
        aria-haspopup="dialog"
        aria-controls="{{ dialog_id }}"
        on:click="/showDialog"
      >
        <span class="contact-form__open-button-icon">
          {{- 'icon-help.svg' | inline_asset_content -}}
        </span>
        {{ block.settings.button_text }}
      </button>

      <dialog
        id="{{ dialog_id }}"
        ref="dialog"
        class="dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}"
        scroll-lock
        aria-labelledby="contact-form-dialog-heading-{{ block.id }}"
        data-testid="contact-form-dialog"
      >
        <h2
          id="contact-form-dialog-heading-{{ block.id }}"
          class="visually-hidden"
        >
          {{ 't:names.contact_form' | t }}
        </h2>
        <button
          ref="closeButton"
          on:click="/closeDialog"
          class="button button-unstyled close-button"
          aria-label="{{ 'actions.close_dialog' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>

        {{ contact_form_markup }}
      </dialog>
    </dialog-component>
  {%- else -%}
    {{ contact_form_markup }}
  {%- endif -%}
</div>

{% stylesheet %}
  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .contact-form__form-row {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);

    @media screen and (min-width: 750px) {
      flex-direction: row;
      align-items: center;
    }
  }

  .contact-form__input {
    width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-input-text);
    background-color: var(--color-input-background);
    padding: var(--padding-lg) var(--padding-xl);
    border-radius: var(--style-border-radius-inputs);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    -webkit-font-smoothing: antialiased;
  }

  .contact-form__input--textarea {
    resize: vertical;
    min-height: var(--input-textarea-min-height);
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
  }

  .contact-form__label,
  .contact-form__legend {
    display: block;
    font: var(--font-body--style) var(--font-body--weight) var(--font-body--size) / var(--font-body--line-height)
      var(--font-body--family);
    color: var(--color-foreground);
  }

  .contact-form__fieldset {
    margin: 0;
    padding: 0;
    border: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
  }

  .contact-form__radio-list {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xs);
  }

  .contact-form__radio-option {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    font: var(--font-body--style) var(--font-body--weight) var(--font-body--size) / var(--font-body--line-height)
      var(--font-body--family);
  }

  .contact-form__whatsapp-group {
    display: grid;
    grid-template-columns: minmax(120px, 180px) 1fr;
    gap: var(--gap-sm);
    width: 100%;
  }

  .contact-form__input--country {
    padding-inline-end: var(--padding-lg);
  }

  .contact-form__error,
  .contact-form__success {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
  }

  .contact-form__stock-label {
    padding-top: 15px;
    margin-bottom: 20px;
    color: #ff9a52;
    font-family: Montserrat, sans-serif;
    font-size: 12px;
    text-transform: uppercase;
  }

  .contact-form__open-button {
    height: 40px;
    font-family: Montserrat, sans-serif;
    font-size: 12px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: var(--gap-xs, 8px);
  }

  .contact-form__open-button-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .contact-form__open-button-icon svg {
    width: 20px;
    height: 20px;
    color: inherit;
  }

  .contact-form__open-button-icon path {
    stroke: currentColor;
    stroke-width: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.contact_form",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "modal_mode",
      "label": "Mode modal",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_out_of_stock",
      "label": "Show out-of-stock",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "t:names.contact_form",
      "visible_if": "{{ block.settings.modal_mode }}"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.contact_form",
      "category": "t:categories.forms"
    }
  ]
}
{% endschema %}
