    {
      "type": "checkbox",
      "id": "text_uppercase",
      "label": "Text uppercase",
      "default": false
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Gap",
      "default": 8
    },
    {
      "type": "url",
      "id": "facebook_url",
