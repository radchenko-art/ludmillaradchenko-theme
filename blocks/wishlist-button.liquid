<div class="wishlist-button-block" {{ block.shopify_attributes }}>
  {% if block.settings.custom_liquid != blank %}
    {{ block.settings.custom_liquid }}
  {% endif %}
</div>

{% stylesheet %}
  .wishlist-button-block {
    position: absolute;
  }

  .wishlist-button-block .st-wishlist-button[data-type="details"] {
    padding: 0 !important;
    border: 2px solid hsl(0 0% 0% / 0.15) !important;
    background-color: transparent !important;
    gap: 0;
  }

  .wishlist-button-block .st-wishlist-button[data-type="details"]:hover {
    opacity: 1 !important;
  }

  .wishlist-button-block .st-wishlist-button[data-type="details"] .st-label {
    margin: 0 8px 0 0 !important;
    margin-inline-start: 0;
  }

  /* Button: round pill, same look as quick-add */
  .wishlist-button-block .st-wishlist-button {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    gap: var(--padding-xs);
    margin: 0 !important;
    padding: 0;
    width: auto;
    min-width: var(--button-size-md);
    height: var(--button-size-md);
    border-radius: 50px;
    border: 2px solid hsl(0 0% 0% / 0.15);
    background: linear-gradient(var(--color-background) 0 100%) padding-box;
    backdrop-filter: blur(20px) saturate(180%);
    color: var(--color-foreground);
    font-family: var(--font-paragraph--family);
    font-size: var(--font-paragraph--size);
    cursor: pointer;
    overflow: hidden;
    transition: scale var(--animation-speed) var(--animation-easing);
  }

  /* Text label: collapsed by default (icon-only), expands on hover */
  .wishlist-button-block .st-wishlist-button .st-label {
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    padding-inline: 0;
    transition: max-width var(--animation-speed) var(--ease-out-cubic),
      padding-inline-start var(--animation-speed) var(--ease-out-cubic);
  }

  .wishlist-button-block .st-wishlist-button:hover .st-label,
  .wishlist-button-block .st-wishlist-button:focus-visible .st-label {
    max-width: 20em;
    padding-inline-start: var(--padding-xs);
  }

  /* Icon size */
  .wishlist-button-block .st-wishlist-button .st-wishlist-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    transform: translate(6.5px, 2px);
    padding: 0;
    margin-right: 4px;
  }

  .wishlist-button-block .st-wishlist-button:hover,
  .wishlist-button-block .st-wishlist-button:focus-visible {
    scale: 1.03;
  }

  .wishlist-button-block .st-wishlist-button:hover::before,
  .wishlist-button-block .st-wishlist-button:focus-visible::before {
    content: '';
    position: absolute;
    inset: -10px;
    z-index: -1;
  }

  .wishlist-button-block .st-wishlist-button:active {
    scale: 0.99;
  }

  @media (prefers-reduced-motion: reduce) {
    .wishlist-button-block .st-wishlist-button .st-label {
      max-width: 20em;
      padding-inline-start: var(--padding-xs);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Wishlist Button",
  "tag": null,
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "Custom HTML / Liquid",
      "info": "Supports Liquid (e.g. {{ product.id }}, {{ closest.product.title }})"
    }
  ],
  "presets": [
    {
      "name": "Wishlist Button",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
