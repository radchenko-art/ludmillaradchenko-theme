<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    <script>
      (function () {
        var OVERRIDE_KEY = 'lr_preferred_store';
        var UAE_ORIGIN = 'https://uae.ludmillaradchenko.art';
        var UAE_HOME = UAE_ORIGIN.replace(/\/$/, '') + '/';

        /** Shared across ludmillaradchenko.art and *.ludmillaradchenko.art (localStorage is per-host). */
        function getSharedCookieDomain() {
          try {
            var host = window.location.hostname.toLowerCase();
            if (host === 'ludmillaradchenko.art' || host.endsWith('.ludmillaradchenko.art')) {
              return '.ludmillaradchenko.art';
            }
          } catch (e) {}
          return '';
        }

        function readCookie(name) {
          var cookies = document.cookie.split(';');
          for (var i = 0; i < cookies.length; i++) {
            var part = cookies[i].replace(/^\s+/, '');
            if (part.indexOf(name + '=') !== 0) continue;
            var value = part.substring(name.length + 1);
            if (value === '') return null;
            try {
              return decodeURIComponent(value);
            } catch (e) {
              return value;
            }
          }
          return null;
        }

        function clearOverride() {
          try {
            window.localStorage.removeItem(OVERRIDE_KEY);
          } catch (e) {}
          var base = OVERRIDE_KEY + '=; path=/; max-age=0';
          document.cookie = base;
          var shared = getSharedCookieDomain();
          if (shared) document.cookie = base + '; domain=' + shared;
        }

        function getOverride() {
          var parsed = null;
          var rawCookie = readCookie(OVERRIDE_KEY);
          if (rawCookie) {
            try {
              parsed = JSON.parse(rawCookie);
            } catch (e) {
              parsed = null;
            }
          }
          if (!parsed || typeof parsed !== 'object') {
            try {
              var rawLs = window.localStorage.getItem(OVERRIDE_KEY);
              if (rawLs) parsed = JSON.parse(rawLs);
            } catch (e) {
              parsed = null;
            }
          }
          if (!parsed || typeof parsed !== 'object') return null;
          if (!parsed.expiresAt || Date.now() > parsed.expiresAt) {
            clearOverride();
            return null;
          }
          if (!parsed.region) return null;
          return parsed; // { region: 'italy'|'uae', expiresAt: number }
        }

        // Respect explicit user choice for 2 hours (set by the region switcher: cookie + localStorage).
        var override = getOverride();
        if (override && override.region) return;

        // Avoid redirect loops / no-op redirects when already on UAE domain.
        try {
          var host = window.location.hostname.toLowerCase();
          if (host === 'uae.ludmillaradchenko.art' || host === 'www.uae.ludmillaradchenko.art') return;
        } catch (e) {}

        function redirectToUaeIfAe(countryCode) {
          if (!countryCode || String(countryCode).toUpperCase() !== 'AE') return;
          window.location.assign(UAE_HOME);
        }

        function fetchCountryCodePrimary() {
          return fetch('https://ipapi.co/json/')
            .then(function (r) {
              if (!r.ok) throw new Error('ipapi_http');
              return r.json();
            })
            .then(function (d) {
              if (d && d.error) throw new Error('ipapi_error');
              if (d && d.country_code) return String(d.country_code).toUpperCase();
              throw new Error('ipapi_no_code');
            });
        }

        function fetchCountryCodeFallback() {
          return fetch('https://get.geojs.io/v1/ip/country.json')
            .then(function (r) {
              if (!r.ok) throw new Error('geojs_http');
              return r.json();
            })
            .then(function (d) {
              if (d && d.country) return String(d.country).toUpperCase();
              throw new Error('geojs_no_code');
            });
        }

        fetchCountryCodePrimary()
          .catch(function () {
            return fetchCountryCodeFallback();
          })
          .then(redirectToUaeIfAe)
          .catch(function () {});
      })();
    </script>

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}{% if template.name == 'index' %} template-index{% endif %}{% if template.name == 'page' and template.suffix != blank %} template-page-{{ template.suffix }}{% endif %}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isMobileHeader = window.matchMedia('(max-width: 991px)').matches;
          headerComponent.dataset.menuStyle = isMobileHeader ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {%- unless template.name == 'index' -%}
        {%- render 'breadcrumbs' -%}
      {%- endunless -%}
      {%- if template.name == 'collection' -%}
        <div class="collection-layout-wrapper section--page-width" data-collection-layout-wrapper>
          <div class="collection-layout-wrapper__center">
            {{ content_for_layout }}
          </div>
        </div>
      {%- else -%}
        {{ content_for_layout }}
      {%- endif -%}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
