{%- liquid
  assign content_raw = page.content
  assign parts = content_raw | split: '<hr'
  assign has_columns = false
  assign content_before = ''
  assign content_after = ''

  if parts.size >= 2
    assign has_columns = true
    assign content_before = parts[0]
    assign rest = parts[1]
    assign rest_split = rest | split: '>'
    assign hr_tail = rest_split[0] | append: '>'
    assign content_after = rest | remove_first: hr_tail
  endif

  assign main_image = page.metafields.custom.main_image.value
  assign subheading = page.metafields.custom.subtitle.value | default: page.metafields.custom.subheading.value
  assign subheading_image = page.metafields.custom.subheading_image.value
  assign right_text = page.metafields.custom.right_text
  assign bg_image = page.metafields.custom.background_image.value
  assign bg_image_url = ''
  if bg_image != blank
    assign bg_image_url = bg_image | image_url: width: 1920
  endif

  assign show_header_row = false
  assign show_single_row_image_text = false
  assign show_about_person_special_layout = false
  assign is_contact_page = false
  if main_image != blank and subheading != blank and has_columns
    assign show_header_row = true
  endif
  if main_image != blank and subheading == blank and has_columns == false
    assign show_single_row_image_text = true
  endif
  if main_image != blank and subheading != blank and bg_image != blank and subheading_image == blank
    assign show_about_person_special_layout = true
  endif
  if page.handle == 'contact'
    assign is_contact_page = true
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section {% if section.settings.content_width == 'narrow' %}page-width-narrow{% else %}section--full-width{% endif %} color-{{ section.settings.color_scheme }}">
  <div
    class="about-person__inner-wrap spacing-style"
    style="--padding-block-start: 0; --padding-block-end: 0; --padding-inline-start: {{ section.settings['padding-inline-start'] | default: 0 }}px; --padding-inline-end: {{ section.settings['padding-inline-end'] | default: 0 }}px;"
  >
    <div
      class="about-person layout-panel-flex layout-panel-flex--column section-content-wrapper mobile-column spacing-style{% if bg_image_url != blank %} section-content-wrapper--has-bg about-person--has-bg{% endif %}"
      style="
        --flex-direction: column;
        --padding-inline-start: 0;
        --padding-inline-end: 0;
        {% render 'gap-style', value: section.settings.gap %}
        {% render 'spacing-style', settings: section.settings %}
        {% if bg_image_url != blank %}
          background-image: url('{{ bg_image_url }}');
          background-attachment: fixed;
          background-repeat: no-repeat;
          background-size: cover;
          color: #fff;
        {% endif %}
      "
    >
    {%- unless show_header_row or show_about_person_special_layout -%}
      <div class="page-content__title-wrapper">
        <h1 class="page-content__title">{{ page.title }}</h1>
      </div>
    {%- endunless -%}

    {%- if show_header_row and show_about_person_special_layout == false -%}
      <div class="page-content__two-columns page-content__header-row">
        <div class="page-content__column">
          {%- if main_image != blank -%}
            <div class="page-content__main-image">
              <img
                src="{{ main_image | image_url: width: 800 }}"
                alt=""
                width="{{ main_image.width }}"
                height="{{ main_image.height }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        </div>
        <div class="page-content__column page-content__column--subheading">
          <h2 class="page-content__subheading">{{ subheading }}</h2>
          {%- if right_text != blank -%}
            <div class="page-content__right-text rte">
              {{ right_text | metafield_tag }}
            </div>
          {%- elsif subheading_image != blank -%}
            <div class="page-content__subheading-image">
              <img
                src="{{ subheading_image | image_url: width: 600 }}"
                alt=""
                width="{{ subheading_image.width }}"
                height="{{ subheading_image.height }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        </div>
      </div>
      <div class="page-content__title-wrapper">
        <h1 class="page-content__title">{{ page.title }}</h1>
      </div>
    {%- endif -%}

    {%- if show_about_person_special_layout -%}
      <div class="page-content__two-columns page-content__about-special">
        <div class="page-content__column">
          <div class="page-content__main-image">
            <img
              src="{{ main_image | image_url: width: 800 }}"
              alt=""
              width="{{ main_image.width }}"
              height="{{ main_image.height }}"
              loading="lazy"
            >
          </div>
        </div>
        <div class="page-content__column page-content__column--subheading page-content__column--text">
          <h2 class="page-content__subheading">{{ subheading }}</h2>
          <rte-formatter>{{ content_raw }}</rte-formatter>
          {%- if is_contact_page -%}
            <div class="page-content__contact-actions">
              <a href="/collections/available-works" class="page-content__download-link">
                👉 Invest in my art / Collect available works
              </a>
              <a
                href="https://taplink.cc/ludmillaradchenko"
                class="page-content__download-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                📚 Full Catalogue
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- if is_contact_page -%}
        {% assign about_contact_form_id = 'AboutPersonContactForm' %}
        {%- form 'contact', id: about_contact_form_id, class: 'about-person-contact-form page-content__contact-form-wrap' -%}
          <input type="hidden" name="contact[tags]" value="about-person">

          {%- if form.posted_successfully? and form.id == about_contact_form_id -%}
            <p class="about-person-contact-form__success">{{ 'blocks.contact_form.post_success' | t }}</p>
          {%- endif -%}

          {%- if form.errors and form.id == about_contact_form_id -%}
            <p class="about-person-contact-form__error">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </p>
          {%- endif -%}

          <div class="about-person-contact-form__grid">
            <div class="about-person-contact-form__column about-person-contact-form__column--fields">
              <div class="about-person-contact-form__field">
                <label for="{{ about_contact_form_id }}-name" class="about-person-contact-form__label">
                  Name <span aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="{{ about_contact_form_id }}-name"
                  class="about-person-contact-form__input"
                  autocomplete="name"
                  name="contact[name]"
                  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                  required
                >
              </div>

              <div class="about-person-contact-form__field">
                <label for="{{ about_contact_form_id }}-whatsapp" class="about-person-contact-form__label">WhatsApp</label>
                <input
                  type="tel"
                  id="{{ about_contact_form_id }}-whatsapp"
                  class="about-person-contact-form__input"
                  autocomplete="tel"
                  name="contact[WhatsApp]"
                  pattern="[0-9\\-\\+\\s\\(\\)]*"
                  placeholder="Phone number"
                >
              </div>

              <div class="about-person-contact-form__field">
                <label for="{{ about_contact_form_id }}-email" class="about-person-contact-form__label">
                  Email <span aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="{{ about_contact_form_id }}-email"
                  class="about-person-contact-form__input"
                  autocomplete="email"
                  name="contact[email]"
                  spellcheck="false"
                  autocapitalize="off"
                  value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                  aria-required="true"
                  required
                >
              </div>

              <div class="about-person-contact-form__field">
                <label for="{{ about_contact_form_id }}-location" class="about-person-contact-form__label">
                  Location <span aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="{{ about_contact_form_id }}-location"
                  class="about-person-contact-form__input"
                  name="contact[Location]"
                  placeholder="Country / City"
                  required
                >
              </div>

              <div class="about-person-contact-form__field">
                <label for="{{ about_contact_form_id }}-preferred-size" class="about-person-contact-form__label">
                  Preferred Size <span aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="{{ about_contact_form_id }}-preferred-size"
                  class="about-person-contact-form__input"
                  name="contact[Preferred Size]"
                  placeholder="e.g., 100x100 cm or Custom"
                  required
                >
              </div>

              <div class="about-person-contact-form__field">
                <label for="{{ about_contact_form_id }}-body" class="about-person-contact-form__label">
                  Notes / Details <span aria-hidden="true">*</span>
                </label>
                <textarea
                  rows="6"
                  id="{{ about_contact_form_id }}-body"
                  class="about-person-contact-form__input about-person-contact-form__input--textarea"
                  name="contact[body]"
                  placeholder="Describe your idea, colors, or theme..."
                  required
                >{{- form.body -}}</textarea>
              </div>
            </div>

            <div class="about-person-contact-form__column about-person-contact-form__column--options">
              <fieldset class="about-person-contact-form__fieldset">
                <legend class="about-person-contact-form__legend">I'm interested in: <span aria-hidden="true">*</span></legend>
                <div class="about-person-contact-form__radio-list">
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-interest-original">
                    <input
                      id="{{ about_contact_form_id }}-interest-original"
                      type="radio"
                      name="contact[I'm interested in]"
                      value="Original artwork/uniquepiece"
                      required
                    >
                    <span>Original artwork/uniquepiece</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-interest-multiple">
                    <input
                      id="{{ about_contact_form_id }}-interest-multiple"
                      type="radio"
                      name="contact[I'm interested in]"
                      value="Multiple Art- limited edition prints"
                    >
                    <span>Multiple Art- limited edition prints</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-interest-commission">
                    <input
                      id="{{ about_contact_form_id }}-interest-commission"
                      type="radio"
                      name="contact[I'm interested in]"
                      value="Сommission /personalized order"
                    >
                    <span>Сommission /personalized order</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-interest-brand">
                    <input
                      id="{{ about_contact_form_id }}-interest-brand"
                      type="radio"
                      name="contact[I'm interested in]"
                      value="Brand Collaboration"
                    >
                    <span>Brand Collaboration</span>
                  </label>
                </div>
              </fieldset>

              <fieldset class="about-person-contact-form__fieldset">
                <legend class="about-person-contact-form__legend">Select your budget range <span aria-hidden="true">*</span></legend>
                <div class="about-person-contact-form__radio-list">
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-budget-under-2000">
                    <input
                      id="{{ about_contact_form_id }}-budget-under-2000"
                      type="radio"
                      name="contact[Select your budget range]"
                      value="Under €2,000"
                      required
                    >
                    <span>Under €2,000</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-budget-2000-5000">
                    <input
                      id="{{ about_contact_form_id }}-budget-2000-5000"
                      type="radio"
                      name="contact[Select your budget range]"
                      value="€2,000 – €5,000"
                    >
                    <span>€2,000 – €5,000</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-budget-5000-10000">
                    <input
                      id="{{ about_contact_form_id }}-budget-5000-10000"
                      type="radio"
                      name="contact[Select your budget range]"
                      value="€5,000 – €10,000"
                    >
                    <span>€5,000 – €10,000</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-budget-10000-plus">
                    <input
                      id="{{ about_contact_form_id }}-budget-10000-plus"
                      type="radio"
                      name="contact[Select your budget range]"
                      value="€10,000+"
                    >
                    <span>€10,000+</span>
                  </label>
                </div>
              </fieldset>

              <fieldset class="about-person-contact-form__fieldset">
                <legend class="about-person-contact-form__legend">Space Type <span aria-hidden="true">*</span></legend>
                <div class="about-person-contact-form__radio-list">
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-space-home">
                    <input
                      id="{{ about_contact_form_id }}-space-home"
                      type="radio"
                      name="contact[Space Type]"
                      value="Home"
                      required
                    >
                    <span>Home</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-space-office">
                    <input
                      id="{{ about_contact_form_id }}-space-office"
                      type="radio"
                      name="contact[Space Type]"
                      value="Office"
                    >
                    <span>Office</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-space-hotel">
                    <input
                      id="{{ about_contact_form_id }}-space-hotel"
                      type="radio"
                      name="contact[Space Type]"
                      value="Hotel / Restaurant"
                    >
                    <span>Hotel / Restaurant</span>
                  </label>
                  <label class="about-person-contact-form__radio-option" for="{{ about_contact_form_id }}-space-other">
                    <input
                      id="{{ about_contact_form_id }}-space-other"
                      type="radio"
                      name="contact[Space Type]"
                      value="Other"
                    >
                    <span>Other</span>
                  </label>
                </div>
              </fieldset>
            </div>
          </div>

          <button type="submit" class="button page-content__download-link about-person-contact-form__submit">
            {{ 'content.about_person_contact.send_request' | t }}
          </button>
        {%- endform -%}
      {%- endif -%}
    {%- elsif show_single_row_image_text -%}
      <div class="page-content__two-columns">
        <div class="page-content__column">
          <div class="page-content__main-image">
            <img
              src="{{ main_image | image_url: width: 800 }}"
              alt=""
              width="{{ main_image.width }}"
              height="{{ main_image.height }}"
              loading="lazy"
            >
          </div>
        </div>
        <div class="page-content__column page-content__column--text">
          <rte-formatter>{{ content_raw }}</rte-formatter>
        </div>
      </div>
    {%- elsif has_columns -%}
      <div class="page-content__two-columns">
        <div class="page-content__column page-content__column--text">
          <rte-formatter>{{ content_before }}</rte-formatter>
        </div>
        <div class="page-content__column page-content__column--text">
          <rte-formatter>{{ content_after }}</rte-formatter>
        </div>
      </div>
    {%- else -%}
      <rte-formatter>{{ content_raw }}</rte-formatter>
    {%- endif -%}

    {%- assign download_files = page.metafields.custom.download_files.value -%}
    {%- if download_files != blank -%}
      {%- capture download_urls -%}
        {%- if download_files.url != blank -%}
          {{- download_files.url -}}|||
        {%- else -%}
          {%- for file in download_files -%}
            {%- assign file_url = file.url | default: file -%}
            {%- if file_url != blank -%}{{- file_url -}}|||{%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endcapture -%}

      {%- assign download_urls_array = download_urls | split: '|||' -%}
      <div class="page-content__downloads">
        {%- for file_url in download_urls_array -%}
          {%- assign file_url = file_url | strip -%}
          {%- if file_url != blank -%}
            {%- assign filename = file_url | split: '?' | first | split: '/' | last -%}
            {%- assign ext = filename | split: '.' | last -%}
            {%- assign suffix = '.' | append: ext -%}
            {%- assign name_only = filename | remove: suffix -%}
            {%- assign link_text = name_only | replace: '-', ' ' | replace: '_', ' ' -%}
            <a href="{{ file_url }}" class="page-content__download-link" download>{{ link_text }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .about-person--has-bg {
    position: relative;
  }

  .about-person--has-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.54);
    pointer-events: none;
  }

  .about-person--has-bg > * {
    position: relative;
    z-index: 1;
  }

  .about-person--has-bg,
  .about-person--has-bg h1,
  .about-person--has-bg h2,
  .about-person--has-bg h3,
  .about-person--has-bg h4,
  .about-person--has-bg .rte,
  .about-person--has-bg .rte p,
  .about-person--has-bg .rte a,
  .about-person--has-bg .rte li,
  .about-person--has-bg .text-block {
    color: #fff;
  }

  .about-person--has-bg .rte a:not(.page-content__download-link) {
    border-bottom-color: rgba(255, 255, 255, 0.6);
  }

  @media screen and (max-width: 499px) {
    .about-person__inner-wrap.spacing-style {
      padding-inline: 0 !important;
    }
  }

  @media screen and (min-width: 750px) {
    .about-person.spacing-style.layout-panel-flex.layout-panel-flex--column.section-content-wrapper.mobile-column {
      padding-left: 15px;
      padding-right: 15px;
    }
  }

  .about-person--has-bg h1 {
    font-family: var(--font-accent--family);
    font-size: 54px;
    text-transform: none;
  }

  .page-content__two-columns {
    display: grid;
    gap: var(--gap-lg, 1rem);
  }

  .page-content__header-row {
    margin-bottom: var(--gap-lg, 1rem);
  }

  .page-content__subheading-image {
    margin-top: 1rem;
  }

  .page-content__column--subheading {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .page-content__subheading {
    font-size: 30px;
    font-weight: 600;
    margin: 0;
  }

  .page-content__title-wrapper {
    width: 100%;
    text-align: center;
    margin-bottom: var(--gap-lg, 1rem);
  }

  .page-content__title {
    margin: 0;
    padding: 0 0 20px;
  }

  .page-content__header-row + .page-content__title-wrapper .page-content__title {
    padding: 20px 0;
  }

  .page-content__column--text {
    padding: 0 40px;
    text-align: justify;
    font-size: 15px;
  }

  .page-content__column--text p {
    line-height: 28.5px;
    margin-bottom: 16px;
  }

  .page-content__downloads {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-content__download-link {
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background-color: #ce2d2a;
    border-radius: 50px;
    padding: 15px 50px;
    border: 3px solid #ce2d2a;
    border-bottom-color: #ce2d2a;
    text-decoration: none;
    text-align: center;
    transition: 0.5s;
    display: inline-block;
    line-height: 1;
    color: #ffffff;
  }

  .page-content__download-link:hover {
    color: #ffffff;
    background-color: rgba(0, 0, 0, 0);
    border: 3px solid #ffffff;
    border-bottom-color: #ffffff;
    font-weight: 500;
  }

  .page-content__download-link {
    white-space: nowrap;
  }

  .page-content__about-special .page-content__column--subheading {
    align-items: flex-start;
    justify-content: flex-start;
    text-align: left;
  }

  .page-content__about-special .page-content__subheading {
    margin-bottom: 16px;
    text-align: center;
  }

  .page-content__contact-actions {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    align-items: flex-start;
  }

  .page-content__contact-actions .page-content__download-link {
    white-space: nowrap;
    text-align: center;
    width: 100%;
  }

  @media screen and (max-width: 1300px) {
    .page-content__contact-actions .page-content__download-link {
      white-space: normal;
    }
  }

  .page-content__contact-form-wrap {
    width: 100%;
    max-width: 1140px;
    margin: 32px auto 0;
  }

  .about-person-contact-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0;
    background: transparent;
  }

  .about-person-contact-form__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .about-person-contact-form__column {
    min-width: 0;
  }

  .about-person-contact-form__field {
    margin-bottom: 24px;
  }

  .about-person-contact-form__fieldset {
    margin: 0 0 24px;
    padding: 0;
    border: 0;
  }

  .about-person-contact-form__legend {
    display: block;
    margin-bottom: 8px;
  }

  .about-person-contact-form__label {
    display: block;
    margin-bottom: 8px;
  }

  .about-person-contact-form__radio-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .about-person-contact-form__radio-option {
    position: relative;
    display: block;
    cursor: pointer;
  }

  .about-person-contact-form__radio-option input[type='radio'] {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    margin: 0;
    pointer-events: none;
  }

  .about-person-contact-form__radio-option span {
    position: relative;
    display: inline-block;
    padding-left: 28px;
    line-height: 1.4;
  }

  .about-person-contact-form__radio-option span::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid #fff;
    background-color: #fff;
    transform: translateY(-50%);
    box-sizing: border-box;
  }

  .about-person-contact-form__radio-option span::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: darkred;
    transform: translateY(-50%) scale(0);
    transition: transform 0.2s ease;
  }

  .about-person-contact-form__radio-option input[type='radio']:checked + span::before {
    border-color: darkred;
  }

  .about-person-contact-form__radio-option input[type='radio']:checked + span::after {
    transform: translateY(-50%) scale(1);
  }

  .about-person-contact-form__radio-option input[type='radio']:focus-visible + span::before {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .section-about-person .about-person-contact-form :is(input, textarea, select).about-person-contact-form__input {
    width: 100%;
    padding: 12px 14px;
    border: 0;
    outline: 0;
    box-shadow: none;
    border-radius: 3px;
    background-color: #fff;
    color: #000;
    opacity: 1;
  }

  .section-about-person .about-person-contact-form :is(input, textarea, select).about-person-contact-form__input:focus,
  .section-about-person .about-person-contact-form :is(input, textarea, select).about-person-contact-form__input:focus-visible {
    outline: 0;
    box-shadow: none;
  }

  .about-person-contact-form__input::placeholder {
    color: #777;
  }

  .about-person-contact-form__input--textarea {
    resize: vertical;
    height: 100px;
    min-height: 100px;
  }

  .about-person-contact-form__submit {
    align-self: center;
    margin-top: 0;
  }

  .about-person-contact-form__success,
  .about-person-contact-form__error {
    margin: 0 0 24px;
  }

  @media screen and (min-width: 750px) {
    .page-content__two-columns {
      grid-template-columns: 1fr 1fr;
      max-width: 1140px;
      margin-inline: auto;
    }

    .page-content__contact-actions {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
    }

    .page-content__contact-actions .page-content__download-link {
      width: auto;
    }

    .about-person-contact-form__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .page-content__title-wrapper {
      max-width: 1140px;
      margin-inline: auto;
    }

    .page-content__right-text {
      padding-inline: 40px;
      margin-top: 20px;
      text-align: center;
    }
  }
{% endstylesheet %}

