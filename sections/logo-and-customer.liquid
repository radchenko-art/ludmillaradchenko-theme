<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="logo-and-customer spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px;"
>
  <div class="logo-and-customer__row">
    <button
      type="button"
      class="button button-unstyled logo-and-customer__menu-trigger"
      aria-label="{{ 'accessibility.menu' | t }}"
      data-logo-customer-menu-trigger
    >
      <span class="svg-wrapper" aria-hidden="true">{{ 'icon-menu.svg' | inline_asset_content }}</span>
    </button>

    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'region_selector' %}
          {% liquid
            assign region_loc_font = 'heading'
            assign region_loc_font_size = '0.875rem'
            for cm in section.blocks
              if cm.type == 'customer_menu'
                assign region_loc_font = cm.settings.localization_font
                assign region_loc_font_size = cm.settings.localization_font_size
              endif
            endfor
          %}
          {% render 'logo-and-customer-region-selector',
            block: block,
            localization_font: region_loc_font,
            localization_font_size: region_loc_font_size
          %}
        {% when 'logo_block' %}
          {% render 'logo-and-customer-logo-markup', block: block %}
        {% when 'customer_menu' %}
          {% render 'logo-and-customer-actions-markup', block: block %}
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% liquid
  assign load_region_selector_js = false
  for b in section.blocks
    if b.type == 'region_selector'
      assign load_region_selector_js = true
    endif
  endfor
%}
{% if load_region_selector_js %}
  <script src="{{ 'logo-and-customer-region-selector.js' | asset_url }}" defer></script>
{% endif %}

{% stylesheet %}
  .logo-and-customer {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
    min-height: 160px;
  }

  .logo-and-customer__row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: var(--gap-xl);
  }

  /* One row: region + logo left group, customer actions pinned to the end */
  .logo-and-customer__row .logo-and-customer__actions {
    margin-inline-start: auto;
    flex-shrink: 0;
  }

  .logo-and-customer__row .logo-and-customer__region {
    flex-shrink: 0;
  }

  .logo-and-customer__row .logo-and-customer__logo {
    flex-shrink: 1;
    min-width: 0;
  }

  /* Center logo: region (left) | logo (center) | actions (right) — one row */
  .logo-and-customer__row:has(.logo-and-customer__logo--center) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    justify-items: stretch;
    gap: var(--gap-xl);
  }

  .logo-and-customer__row:has(.logo-and-customer__logo--center) .logo-and-customer__logo--center {
    grid-column: 2;
    justify-self: center;
  }

  .logo-and-customer__row:has(.logo-and-customer__logo--center) .logo-and-customer__actions {
    grid-column: 3;
    justify-self: end;
    margin-inline-start: 0;
  }

  .logo-and-customer__row:has(.logo-and-customer__logo--center) .logo-and-customer__region {
    grid-column: 1;
    justify-self: start;
  }

  .logo-and-customer__region {
    display: flex;
    align-items: center;
  }

  /* Match header Customer menu → localization dropdown trigger (sections/header.liquid) */
  .logo-and-customer__region.dropdown-localization .logo-and-customer-region__trigger.dropdown-localization__button {
    display: flex;
    position: relative;
    align-items: center;
    gap: 4px;
    font-family: var(--menu-localization-font);
    font-size: var(--menu-localization-font-size);
    font-weight: var(--menu-top-level-font-weight);
    padding-inline: var(--padding-2xs);
    margin-inline: calc(-1 * var(--padding-2xs));
    max-width: min(100%, 14rem);
    box-shadow: none;
    background-color: transparent;
    border-color: transparent;
    color: var(--color-foreground);
    cursor: pointer;
    text-align: start;
  }

  .logo-and-customer__region.dropdown-localization .logo-and-customer-region__trigger.dropdown-localization__button,
  .logo-and-customer__region.dropdown-localization .logo-and-customer-region__trigger.dropdown-localization__button:hover {
    box-shadow: none;
    background-color: transparent;
    border-color: transparent;
    color: var(--color-foreground);
  }

  .logo-and-customer__region.dropdown-localization .logo-and-customer-region__trigger .icon-caret {
    height: var(--icon-size-xs);
    width: var(--icon-size-xs);
    flex-shrink: 0;
    transition: transform var(--animation-speed) var(--animation-easing);
    pointer-events: none;
  }

  .logo-and-customer__region.dropdown-localization .logo-and-customer-region__select {
    flex: 1;
    min-width: 0;
    margin: 0;
    padding: 0;
    border: none;
    appearance: none;
    background-color: transparent;
    color: inherit;
    font: inherit;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    cursor: pointer;
    text-overflow: ellipsis;
  }

  .logo-and-customer__region.dropdown-localization .logo-and-customer-region__select:focus {
    outline: none;
  }

  .logo-and-customer__region.dropdown-localization .logo-and-customer-region__trigger:focus-within {
    outline: 2px solid rgb(var(--color-foreground-rgb) / 0.35);
    outline-offset: 2px;
  }

  .logo-and-customer__logo {
    display: flex;
    align-items: center;
  }

  .logo-and-customer__logo--left {
    justify-content: flex-start;
  }

  .logo-and-customer__logo--center {
    justify-content: center;
  }

  .logo-and-customer__logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-foreground);
    font-weight: 600;
  }

  .logo-and-customer__logo-link:hover {
    text-decoration: none;
    color: var(--color-foreground);
  }

  .logo-and-customer__logo-image {
    object-fit: contain;
    /* Keep logo size constant on mobile and desktop */
    height: var(--logo-image-height);
    width: var(--logo-image-width);
  }

  .logo-and-customer__logo-text {
    font-size: 1.25rem;
  }

  .logo-and-customer__actions {
    display: flex;
    align-items: center;
    gap: var(--logo-and-customer-actions-gap, var(--gap-xl));
  }

  /* Equal spacing between all icons (search, localization, account, cart) */
  .logo-and-customer__menu-trigger {
    display: none;
    width: 40px;
    height: 40px;
    min-width: 40px;
    min-height: 40px;
    align-items: center;
    justify-content: center;
    justify-self: start;
    align-self: center;
  }

  .logo-and-customer__menu-trigger .svg-wrapper {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-and-customer__menu-trigger .svg-wrapper svg {
    width: calc(var(--icon-size-xs) * 2);
    height: calc(var(--icon-size-xs) * 2);
  }

  .logo-and-customer__menu-trigger .svg-wrapper svg path {
    stroke-width: 1.5px;
  }

  .logo-and-customer__actions header-actions {
    display: flex;
    align-items: center;
    gap: var(--logo-and-customer-actions-gap, var(--gap-xl));
  }

  @media screen and (max-width: 991px) {
    .logo-and-customer.spacing-style {
      --padding-block-start: 0px !important;
    }

    .logo-and-customer__menu-trigger {
      display: inline-flex;
      grid-column: 1;
      justify-self: start;
    }

    .logo-and-customer__row:has(.logo-and-customer__logo--center) {
      position: relative;
      padding-top: calc(40px + var(--padding-2xs));
    }

    .logo-and-customer__row:has(.logo-and-customer__logo--center)::after {
      content: '';
      position: absolute;
      inset-inline-start: 50%;
      transform: translateX(-50%);
      top: 40px;
      width: 100vw;
      border-bottom: 1px solid #e6e6e6;
      pointer-events: none;
    }

    .logo-and-customer__row:has(.logo-and-customer__logo--center) .logo-and-customer__actions .header-actions__account {
      position: absolute;
      top: 0;
      right: 0;
      display: flex;
      align-items: center;
      min-height: 40px;
      z-index: 2;
    }

    /* Mobile account menu should behave like desktop popover (no drawer overlay) */
    .logo-and-customer__row:has(.logo-and-customer__logo--center) .logo-and-customer__actions .header-actions__account .account-popover.mobile\:hidden {
      display: block !important;
    }

    .logo-and-customer__row:has(.logo-and-customer__logo--center) .logo-and-customer__actions .header-actions__account .account-drawer {
      display: none !important;
    }

    /* Future hook: language/currency on the left in top 40px row */
    .logo-and-customer__row:has(.logo-and-customer__logo--center) .header-mobile-localization {
      position: absolute;
      top: 0;
      left: 0;
      display: flex;
      align-items: center;
      min-height: 40px;
      z-index: 2;
    }

    .logo-and-customer__row:has(.logo-and-customer__logo--center):has(.logo-and-customer__region) .logo-and-customer__region {
      position: absolute;
      top: 0;
      inset-inline-start: 48px;
      display: flex;
      align-items: center;
      min-height: 40px;
      z-index: 2;
      margin-inline-end: 0;
      /* Do not reserve a grid track; burger stays in column 1 */
      grid-column: unset;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Logo and customer",
  "tag": "aside",
  "class": "logo-and-customer-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "blocks": [
    {
      "type": "region_selector",
      "name": "Store region",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Italy and UAE appear in a dropdown with flags. Choosing a region opens the same path on that domain. In the theme editor, changing the selection does not redirect."
        },
        {
          "type": "text",
          "id": "italy_store_url",
          "label": "Italy store URL",
          "default": "https://ludmillaradchenko.art"
        },
        {
          "type": "text",
          "id": "uae_store_url",
          "label": "UAE store URL",
          "default": "https://uae.ludmillaradchenko.art"
        },
        {
          "type": "select",
          "id": "fallback_region",
          "label": "Default selection (preview / unknown host)",
          "options": [
            { "value": "italy", "label": "Italy" },
            { "value": "uae", "label": "UAE" }
          ],
          "default": "italy"
        },
        {
          "type": "text",
          "id": "label_italy",
          "label": "Italy label",
          "default": "Italy"
        },
        {
          "type": "text",
          "id": "label_uae",
          "label": "UAE label",
          "default": "UAE"
        },
        {
          "type": "text",
          "id": "accessibility_label",
          "label": "Accessibility label",
          "default": "Store region"
        },
        {
          "type": "paragraph",
          "content": "Typography matches the Customer menu block → Localization (font and size)."
        }
      ]
    },
    {
      "type": "logo_block",
      "name": "Logo",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:content.edit_logo_in_theme_settings"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            { "value": "left", "label": "t:options.left" },
            { "value": "center", "label": "t:options.center" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "customer_menu",
      "name": "Customer menu",
      "settings": [
        {
          "type": "header",
          "content": "Spacing"
        },
        {
          "type": "select",
          "id": "icons_gap",
          "label": "t:settings.gap",
          "options": [
            { "value": "0", "label": "t:options.none" },
            { "value": "0.5rem", "label": "t:options.small" },
            { "value": "0.75rem", "label": "t:options.medium" },
            { "value": "1rem", "label": "t:options.large" }
          ],
          "default": "1rem"
        },
        {
          "type": "header",
          "content": "Account"
        },
        {
          "type": "text",
          "id": "account_label",
          "label": "Label after user icon"
        },
        {
          "type": "select",
          "id": "account_menu_behavior",
          "label": "t:settings.account_menu_behavior",
          "options": [
            { "value": "modal", "label": "t:options.modal" },
            { "value": "hover", "label": "t:options.hover" }
          ],
          "default": "modal"
        },
        {
          "type": "header",
          "content": "t:content.search"
        },
        {
          "type": "checkbox",
          "id": "show_search",
          "label": "t:settings.search_icon",
          "default": true
        },
        {
          "type": "header",
          "content": "t:content.localization"
        },
        {
          "type": "checkbox",
          "id": "show_country",
          "label": "t:settings.country_region",
          "info": "t:info.manage_countries_regions",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "country_selector_style",
          "label": "t:settings.flag",
          "default": true,
          "visible_if": "{{ block.settings.show_country }}"
        },
        {
          "type": "checkbox",
          "id": "show_language",
          "label": "t:settings.language_selector",
          "info": "t:info.manage_languages",
          "default": true
        },
        {
          "type": "select",
          "id": "localization_font",
          "label": "t:settings.font",
          "options": [
            { "value": "heading", "label": "t:options.heading" },
            { "value": "subheading", "label": "t:options.subheading" },
            { "value": "body", "label": "t:options.body" },
            { "value": "accent", "label": "t:options.accent" }
          ],
          "default": "heading",
          "visible_if": "{{ block.settings.show_country or block.settings.show_language }}"
        },
        {
          "type": "select",
          "id": "localization_font_size",
          "label": "t:settings.size",
          "options": [
            { "value": "0.625rem", "label": "10px" },
            { "value": "0.75rem", "label": "12px" },
            { "value": "0.875rem", "label": "14px" },
            { "value": "1rem", "label": "16px" },
            { "value": "1.125rem", "label": "18px" }
          ],
          "default": "0.875rem",
          "visible_if": "{{ block.settings.show_country or block.settings.show_language }}"
        },
        {
          "type": "select",
          "id": "localization_position",
          "label": "t:settings.position",
          "options": [
            { "value": "left", "label": "t:options.left" },
            { "value": "right", "label": "t:options.right" }
          ],
          "default": "right",
          "visible_if": "{{ block.settings.show_country or block.settings.show_language }}"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:settings.color_scheme",
          "default": "scheme-1",
          "info": "Used for localization dropdown styling"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Logo and customer",
      "blocks": {
        "region_selector": {
          "type": "region_selector",
          "settings": {
            "italy_store_url": "https://ludmillaradchenko.art",
            "uae_store_url": "https://uae.ludmillaradchenko.art",
            "fallback_region": "italy",
            "label_italy": "Italy",
            "label_uae": "UAE",
            "accessibility_label": "Store region"
          }
        },
        "logo": {
          "type": "logo_block",
          "settings": {
            "position": "left"
          }
        },
        "customer_menu": {
          "type": "customer_menu",
          "settings": {
            "icons_gap": "1rem",
            "show_search": true,
            "show_country": true,
            "country_selector_style": false,
            "show_language": true,
            "localization_font": "heading",
            "localization_font_size": "0.875rem",
            "localization_position": "right",
            "color_scheme": "scheme-1"
          }
        }
      },
      "block_order": ["region_selector", "logo", "customer_menu"]
    }
  ]
}
{% endschema %}
