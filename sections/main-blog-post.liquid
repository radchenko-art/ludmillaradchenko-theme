

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    {% comment %} first_has_native_video: проверка вне {% liquid %}, т.к. Drop (file_reference) в Liquid может давать blank в условии; используем capture вывода первого элемента (как в for) {% endcomment %}
    {% assign article_videos_list = article.metafields.custom.article_videos.value %}
    {% assign first_has_native_video = false %}
    {% assign article_has_exactly_one_video = false %}
    {% if article_videos_list != blank %}
      {% if article_videos_list.size == 1 %}
        {% assign article_has_exactly_one_video = true %}
      {% endif %}
      {% for media_item in article_videos_list limit: 1 %}
        {% capture first_inner_video_output %}{{ media_item.inner_video }}{% endcapture %}
        {% if first_inner_video_output != blank %}
          {% assign first_has_native_video = true %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% liquid
      assign hero_video_block = ''
      assign hero_title_block = ''
      assign hero_content_block = ''
      for bl in section.blocks
        if bl.type == 'article-media-videos' and bl.settings.video_index == 1
          assign hero_video_block = bl
        endif
        if bl.type == 'text' and hero_title_block == blank
          assign hero_title_block = bl
        endif
        if bl.type == 'blog-post-content'
          assign hero_content_block = bl
        endif
      endfor
      assign use_hero_layout = false
      if hero_video_block != blank and hero_title_block != blank and hero_content_block != blank and hero_video_block.settings.video_index == 1 and first_has_native_video
        assign use_hero_layout = true
      endif
    %}

    <div class="article-page__blocks{% unless use_hero_layout %} article-page__blocks--single-column{% endunless %}">
      {% assign hero_row_output = false %}
      {% for block in section.blocks %}
        {% if use_hero_layout and hero_row_output == false %}
          {% if block.id == hero_video_block.id or block.id == hero_title_block.id or block.id == hero_content_block.id %}
            <div class="article-page__hero-row">
              <div class="article-page__hero-col-video">
                {% render 'article-media-videos-block', block: hero_video_block, article: article %}
              </div>
              <div class="article-page__hero-col-text">
                {% render 'text', block: hero_title_block %}
                {% render 'blog-post-content-block', block: hero_content_block, article: article %}
              </div>
            </div>
            {% assign hero_row_output = true %}
            {% continue %}
          {% endif %}
        {% endif %}
        {% if use_hero_layout %}
          {% if block.id == hero_video_block.id or block.id == hero_title_block.id or block.id == hero_content_block.id %}
            {% continue %}
          {% endif %}
        {% endif %}

        {% case block.type %}
          {% when 'text' %}
            {% render 'text', block: block %}
          {% when 'blog-post-details' %}
            {% render 'blog-post-details-block', block: block, article: article %}
          {% when 'blog-post-content' %}
            {% render 'blog-post-content-block', block: block, article: article %}
          {% when 'article-media-videos' %}
            {% comment %} В секции Blog post: не показывать блок, если колонки не сработали и у поста ровно одно видео {% endcomment %}
            {% unless use_hero_layout == false and article_has_exactly_one_video %}
              {% render 'article-media-videos-block', block: block, article: article %}
            {% endunless %}
          {% when 'article-media-gallery' %}
            {% render 'article-media-gallery-block', block: block, article: article %}
          {% when 'image' %}
            {% render 'image-block', block: block %}
          {% when 'blog-post-featured-image' %}
            {% render 'blog-post-featured-image-block', block: block, article: article %}
        {% endcase %}
      {% endfor %}
    </div>

    {% if blog.comments_enabled? %}
      <div class="blog-post-comments-container">
        <h2 class="h3">{{- 'blogs.article.comments_heading' | t: count: article.comments_count -}}</h2>

        <div class="blog-post-comments">
          {% paginate article.comments by 10 %}
            {% for comment in article.comments %}
              <div class="blog-post-comment">
                {{ comment.content }}
                <div class="blog-post-comment__author">
                  <span class="blog-post-comment__author-name">{{- comment.author -}}</span>
                  <span>{{- 'blogs.article.comment_author_separator' | t -}}</span>
                  <span class="blog-post-comment__date">
                    {{- comment.created_at | time_tag: format: 'date' -}}
                  </span>
                </div>
              </div>
            {% endfor %}

            <div class="blog-post-comments-pagination">
              {{- paginate | default_pagination -}}
            </div>
          {% endpaginate %}
        </div>

        {% render 'blog-comment-form', article: article, section_id: section.id %}
      </div>
    {% endif %}
  </div>
</div>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% stylesheet %}
  .article-page__header {
    width: 100%;
  }

  .blog-post-comments-container {
    width: 100%;
    max-width: var(--normal-content-width);
    margin: 0 auto;
  }

  .blog-post-comments {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xl);
  }

  .blog-post-comment__author {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    margin-top: var(--margin-md);
    font-size: var(--font-size--body-sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .blog-post-comments-pagination {
    display: flex;
    justify-content: center;
    gap: var(--gap-2xs);
  }

  .blog-post-comments-pagination,
  .blog-post-comments-pagination a {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a {
    display: block;
    padding: var(--padding-2xs) var(--padding-xs);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a:hover {
    border-bottom: 1px solid var(--color-foreground);
  }

  .article-page__hero-row {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: var(--gap-xl, 2rem);
    width: 100%;
    max-width: var(--normal-content-width, 1140px);
    margin-left: auto;
    margin-right: auto;
    min-width: 0;
  }

  .article-page__hero-col-video {
    flex: 0 0 auto;
    min-width: min(50%, 560px);
    width: min(50%, 560px);
    padding: 5px;
  }

  .article-page__blocks--single-column {
    max-width: 630px;
    margin-left: auto;
    margin-right: auto;
  }

  .article-page__blocks > .text-block {
    margin-bottom: 20px;
  }

  body .section .article-page__blocks .text-block:first-of-type,
  body .section .article-page__blocks .text-block:first-of-type *,
  body .section .article-page__hero-col-text .text-block:first-of-type,
  body .section .article-page__hero-col-text .text-block:first-of-type *,
  body .section .article-page__blocks .text-block--blog-post-title,
  body .section .article-page__blocks .text-block--blog-post-title *,
  body .section .article-page__hero-col-text .text-block--blog-post-title,
  body .section .article-page__hero-col-text .text-block--blog-post-title * {
    color: #ff0000;
    font-size: 22px;
    line-height: 1;
    text-transform: none !important;
  }

  .article-page__hero-col-text > .text-block:first-of-type {
    margin-bottom: 40px;
  }

  .article-page__blocks h2.elementor-heading-title {
    color: #000;
    font-size: 15px;
    font-weight: bold;
  }

  .article-page__hero-col-video .article-media-videos {
    width: 100%;
    max-width: 100%;
  }

  .article-page__hero-col-text {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--gap-lg, 1.5rem);
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .article-page__hero-row {
      flex-direction: column;
    }
    .article-page__hero-col-video {
      width: 100%;
      min-width: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_post",
  "blocks": [
    {
      "type": "text",
      "name": "t:names.text",
      "settings": [
        { "type": "richtext", "id": "text", "label": "t:settings.text" },
        { "type": "header", "content": "t:content.layout" },
        { "type": "select", "id": "width", "label": "t:settings.width", "options": [{ "value": "fit-content", "label": "t:options.fit" }, { "value": "100%", "label": "t:options.fill" }], "default": "fit-content" },
        { "type": "select", "id": "max_width", "label": "t:settings.max_width", "options": [{ "value": "narrow", "label": "t:options.narrow" }, { "value": "normal", "label": "t:options.normal" }, { "value": "none", "label": "t:options.none" }], "default": "normal" },
        { "type": "text_alignment", "id": "alignment", "label": "t:settings.alignment", "default": "left" },
        { "type": "header", "content": "t:content.typography" },
        { "type": "select", "id": "type_preset", "label": "t:settings.preset", "options": [{ "value": "rte", "label": "t:options.default" }, { "value": "paragraph", "label": "t:options.paragraph" }, { "value": "h1", "label": "t:options.h1" }, { "value": "h2", "label": "t:options.h2" }, { "value": "h3", "label": "t:options.h3" }, { "value": "h4", "label": "t:options.h4" }, { "value": "h5", "label": "t:options.h5" }, { "value": "h6", "label": "t:options.h6" }, { "value": "custom", "label": "t:options.custom" }], "default": "rte" },
        { "type": "select", "id": "font", "label": "t:settings.font", "options": [{ "value": "var(--font-body--family)", "label": "t:options.body" }, { "value": "var(--font-subheading--family)", "label": "t:options.subheading" }, { "value": "var(--font-heading--family)", "label": "t:options.heading" }, { "value": "var(--font-accent--family)", "label": "t:options.accent" }], "default": "var(--font-body--family)" },
        { "type": "select", "id": "font_size", "label": "t:settings.size", "options": [{ "value": "", "label": "t:options.default" }, { "value": "1rem", "label": "16px" }, { "value": "1.5rem", "label": "24px" }, { "value": "2rem", "label": "32px" }], "default": "1rem" },
        { "type": "select", "id": "line_height", "label": "t:settings.line_height", "options": [{ "value": "tight", "label": "t:options.tight" }, { "value": "normal", "label": "t:options.normal" }, { "value": "loose", "label": "t:options.loose" }], "default": "normal" },
        { "type": "select", "id": "letter_spacing", "label": "t:settings.letter_spacing", "options": [{ "value": "tight", "label": "t:options.tight" }, { "value": "normal", "label": "t:options.normal" }, { "value": "loose", "label": "t:options.loose" }], "default": "normal" },
        { "type": "select", "id": "case", "label": "t:settings.case", "options": [{ "value": "none", "label": "t:options.default" }, { "value": "uppercase", "label": "t:options.uppercase" }], "default": "none" },
        { "type": "select", "id": "color", "label": "t:settings.color", "options": [{ "value": "var(--color-foreground)", "label": "t:options.text" }, { "value": "var(--color-foreground-heading)", "label": "t:options.heading" }, { "value": "var(--color-primary)", "label": "t:options.link" }], "default": "var(--color-foreground)" },
        { "type": "header", "content": "t:content.appearance" },
        { "type": "checkbox", "id": "background", "label": "t:settings.background", "default": false },
        { "type": "color", "id": "background_color", "label": "t:settings.background_color", "alpha": true, "default": "#00000026" },
        { "type": "range", "id": "corner_radius", "label": "t:settings.corner_radius", "default": 0, "min": 0, "max": 50, "step": 1 },
        { "type": "header", "content": "t:content.padding" },
        { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-inline-start", "label": "t:settings.left", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-inline-end", "label": "t:settings.right", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
      ]
    },
    {
      "type": "blog-post-details",
      "name": "t:names.details",
      "settings": [
        { "type": "checkbox", "id": "show_date", "label": "t:settings.show_date", "default": true },
        { "type": "select", "id": "date_format", "label": "Date format", "options": [{ "value": "", "label": "Default (locale)" }, { "value": "dd_mm_yyyy", "label": "DD/MM/YYYY" }], "default": "" },
        { "type": "checkbox", "id": "show_author", "label": "t:settings.show_author", "default": true },
        { "type": "header", "content": "t:content.typography" },
        { "type": "select", "id": "type_preset", "label": "t:settings.preset", "options": [{ "value": "", "label": "t:options.default" }, { "value": "paragraph", "label": "t:options.paragraph" }, { "value": "h1", "label": "t:options.h1" }, { "value": "h2", "label": "t:options.h2" }, { "value": "h3", "label": "t:options.h3" }, { "value": "h4", "label": "t:options.h4" }, { "value": "h5", "label": "t:options.h5" }, { "value": "h6", "label": "t:options.h6" }], "default": "" },
        { "type": "text_alignment", "id": "alignment", "label": "t:settings.alignment" },
        { "type": "checkbox", "id": "show_alignment", "label": "t:settings.show_alignment", "default": true },
        { "type": "header", "content": "t:content.padding" },
        { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 24 },
        { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
      ]
    },
    {
      "type": "blog-post-content",
      "name": "t:names.content",
      "settings": []
    },
    {
      "type": "article-media-videos",
      "name": "Article media videos",
      "settings": [
        { "type": "range", "id": "video_index", "min": 0, "max": 20, "step": 1, "default": 0, "label": "Video number", "info": "0 = all, 1 = first, 2 = second..." },
        { "type": "checkbox", "id": "video_hosting_only", "label": "Video hosting only", "default": false },
        { "type": "header", "content": "Width" },
        { "type": "select", "id": "width_mode", "label": "Width", "options": [{ "value": "full", "label": "Full" }, { "value": "fit_content", "label": "Fit content" }, { "value": "normal", "label": "Normal" }], "default": "full" },
        { "type": "range", "id": "custom_width_px", "min": 320, "max": 1200, "step": 20, "default": 640, "unit": "px", "label": "Player width (px)" }
      ]
    },
    {
      "type": "article-media-gallery",
      "name": "Article media gallery",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "header", "content": "Padding" },
        { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 1, "default": 0, "unit": "px", "label": "Padding top" },
        { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 1, "default": 0, "unit": "px", "label": "Padding bottom" }
      ]
    },
    {
      "type": "image",
      "name": "t:names.image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:settings.image" },
        { "type": "url", "id": "link", "label": "t:settings.link" },
        { "type": "header", "content": "t:content.size" },
        { "type": "select", "id": "image_ratio", "label": "t:settings.aspect_ratio", "options": [{ "value": "adapt", "label": "t:options.auto" }, { "value": "portrait", "label": "t:options.portrait" }, { "value": "square", "label": "t:options.square" }, { "value": "landscape", "label": "t:options.landscape" }], "default": "adapt" },
        { "type": "select", "id": "width", "label": "t:settings.width_desktop", "options": [{ "value": "fit-content", "label": "t:options.fit_content" }, { "value": "fill", "label": "t:options.fill" }, { "value": "custom", "label": "t:options.custom" }], "default": "fill" },
        { "type": "range", "id": "custom_width", "label": "t:settings.custom_width", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 100 },
        { "type": "select", "id": "width_mobile", "label": "t:settings.width_mobile", "options": [{ "value": "fit-content", "label": "t:options.fit_content" }, { "value": "fill", "label": "t:options.fill" }, { "value": "custom", "label": "t:options.custom" }], "default": "fill" },
        { "type": "range", "id": "custom_width_mobile", "label": "t:settings.custom_width", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 100 },
        { "type": "select", "id": "height", "label": "t:settings.height", "options": [{ "value": "fit", "label": "t:options.fit_content" }, { "value": "fill", "label": "t:options.fill" }], "default": "fit" },
        { "type": "header", "content": "t:content.borders" },
        { "type": "select", "id": "border", "label": "t:settings.style", "options": [{ "value": "none", "label": "t:options.none" }, { "value": "solid", "label": "t:options.solid" }], "default": "none" },
        { "type": "range", "id": "border_width", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "t:settings.thickness", "default": 1 },
        { "type": "range", "id": "border_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "t:settings.opacity", "default": 100 },
        { "type": "range", "id": "border_radius", "label": "t:settings.border_radius", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "header", "content": "t:content.padding" },
        { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-inline-start", "label": "t:settings.left", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-inline-end", "label": "t:settings.right", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
      ]
    },
    {
      "type": "blog-post-featured-image",
      "name": "t:names.featured_image",
      "settings": [
        { "type": "header", "content": "t:content.size" },
        { "type": "select", "id": "image_ratio", "label": "t:settings.aspect_ratio", "options": [{ "value": "adapt", "label": "t:options.auto" }, { "value": "portrait", "label": "t:options.portrait" }, { "value": "square", "label": "t:options.square" }, { "value": "landscape", "label": "t:options.landscape" }], "default": "adapt" },
        { "type": "select", "id": "width", "label": "t:settings.width_desktop", "options": [{ "value": "fit-content", "label": "t:options.fit_content" }, { "value": "fill", "label": "t:options.fill" }, { "value": "custom", "label": "t:options.custom" }], "default": "fill" },
        { "type": "range", "id": "custom_width", "label": "t:settings.custom_width", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 100 },
        { "type": "select", "id": "width_mobile", "label": "t:settings.width_mobile", "options": [{ "value": "fit-content", "label": "t:options.fit_content" }, { "value": "fill", "label": "t:options.fill" }, { "value": "custom", "label": "t:options.custom" }], "default": "fill" },
        { "type": "range", "id": "custom_width_mobile", "label": "t:settings.custom_width", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 100 },
        { "type": "select", "id": "height", "label": "t:settings.height", "options": [{ "value": "fit", "label": "t:options.fit_content" }, { "value": "fill", "label": "t:options.fill" }], "default": "fit" },
        { "type": "header", "content": "t:content.borders" },
        { "type": "select", "id": "border", "label": "t:settings.style", "options": [{ "value": "none", "label": "t:options.none" }, { "value": "solid", "label": "t:options.solid" }], "default": "none" },
        { "type": "range", "id": "border_width", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "t:settings.thickness", "default": 1 },
        { "type": "range", "id": "border_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "t:settings.opacity", "default": 100 },
        { "type": "range", "id": "border_radius", "label": "t:settings.border_radius", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "header", "content": "t:content.padding" },
        { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-inline-start", "label": "t:settings.left", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
        { "type": "range", "id": "padding-inline-end", "label": "t:settings.right", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
      ]
    }
  ],
  "class": "section-wrapper",
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
