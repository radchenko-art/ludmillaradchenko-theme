

<script
  src="{{ 'blog-posts-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<blog-posts-list section-id="{{ section.id }}">
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="
      section
      color-{{ section.settings.color_scheme }}
      blog-posts
      spacing-style
      size-style
    "
    data-testid="blog-posts"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="blog-posts__header">
      {% content_for 'blocks' %}
    </div>

    <div
      ref="grid"
      class="blog-posts-container"
    >
      {% liquid
        capture article_sort_rows
          for article in blog.articles
            assign event_date = article.metafields.custom.event_date.value | default: article.metafields.custom.event_date
            assign sort_date = event_date | default: article.published_at
            assign sort_timestamp = sort_date | date: '%s'

            echo sort_timestamp
            echo '::'
            echo forloop.index0
            echo '||'
          endfor
        endcapture

        assign sorted_article_rows = article_sort_rows | split: '||' | sort | reverse
        assign items_on_page = blog.articles.size
      %}
      {% for sorted_row in sorted_article_rows %}
        {% if sorted_row == blank %}
          {% continue %}
        {% endif %}

        {% assign sorted_row_parts = sorted_row | split: '::' %}
        {% assign article_index = sorted_row_parts[1] | plus: 0 %}

        {% for article in blog.articles %}
          {% if forloop.index0 != article_index %}
            {% continue %}
          {% endif %}

          {% assign is_even = forloop.parentloop.index | modulo: 2 %}
          {% style %}
            [data-blog-index="{{ section.id }}-{{ forloop.parentloop.index }}"] {
              --col-span: 6;
              --blog-post-card-scale: 1;
            }

            @media screen and (max-width: 749px) {
              [data-blog-index="{{ section.id }}-{{ forloop.parentloop.index }}"] {
                --col-span: 6;
                --blog-post-card-scale: 1;
              }
            }
          {% endstyle %}
          <div
            class="blog-post-item blog-post-item--donor{% if is_even == 0 %} blog-post-item--even{% endif %}"
            data-testid="blog-post-item"
            data-blog-index="{{ section.id }}-{{ forloop.parentloop.index }}"
          >
            {% content_for 'block', id: 'static-blog-post-card', type: '_blog-post-card', article: article %}
          </div>

          {% break %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</blog-posts-list>

{% stylesheet %}
  /**
   * Blog posts page layout
   */
  .blog-posts {
    --page-content-width: var(--narrow-page-width);
    --page-width: calc(var(--page-content-width) + (var(--page-margin) * 2));
    --columns-gap: {{ section.settings.columns_gap }}px;
    --rows-gap: {{ section.settings.rows_gap }}px;
  }

  .blog-posts__header {
    text-align: center;
    margin: 0 auto;
  }

  /* Title блока Blog posts (название блога) — переопределяем стили темы */
  .blog-posts .blog-posts__header .text-block h1,
  .blog-posts .blog-posts__header .text-block :is(h1, h2, h3, h4, h5, h6) {
    color: #ff0000 !important;
    text-transform: uppercase !important;
    font-size: 22px !important;
  }

  .blog-posts-container {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    width: 100%;
    column-gap: var(--columns-gap);
    row-gap: var(--rows-gap);
  }

  .blog-post-item {
    grid-column: span var(--col-span);
  }

  .blog-post-item--donor {
    border: none;
    padding: 0;
  }

  .blog-post-item--even .blog-post-card__row {
    flex-direction: row-reverse;
  }

  @media screen and (max-width: 749px) {
    .blog-post-item--even .blog-post-card__row {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_posts",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Grid spacing"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Column gap (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "Row gap (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
