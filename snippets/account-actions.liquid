<div class="account-actions">
  <div class="account-actions__main-menu">
    {% unless customer %}
      <div
        class="account-actions__sign-ins"
        data-skip-subtree-update="true"
      >
        <script
          src="{{ 'account-login-actions.js' | asset_url }}"
          type="module"
          fetchpriority="low"
        ></script>
        <div class="account-actions__sign-in-shop-wrap">
          <account-login-actions class="account-actions__shop-login">
            {{ shop | login_button }}
          </account-login-actions>
          <button
            type="button"
            class="account-actions__sign-in-shop-custom button-unstyled account-actions__row p-0"
            data-shop-login-trigger
            aria-label="{{ 'actions.sign_in_with_shop' | t }}"
          >
            <span class="account-actions__icon" aria-hidden="true">
              {{- 'icon-lock.svg' | inline_asset_content -}}
            </span>
            {{ 'actions.sign_in_with_shop' | t }}
          </button>
        </div>

        <a
          href="{% if request.design_mode %}{{ routes.account_url }}{% else %}{{ routes.storefront_login_url }}{% endif %}"
          class="account-actions__link account-actions__link--primary button-unstyled account-actions__row"
          target="_top"
          rel="noopener"
        >
          <span class="account-actions__icon" aria-hidden="true">
            {{- 'icon-account.svg' | inline_asset_content -}}
          </span>
          <span class="account-actions__sign-in-text">
            {{ 'actions.sign_in_options' | t }}
          </span>
          <span class="account-actions__fallback-text">
            {{ 'actions.log_in' | t }}
          </span>
        </a>
      </div>
    {% endunless %}

    <nav class="account-actions__nav" aria-label="{{ 'content.account_title' | t }}">
      <ul class="account-actions__list">
        {% if customer %}
          <li class="account-actions__list-item">
            <span class="account-actions__row account-actions__row--identity">
              <span class="account-actions__icon" aria-hidden="true">
                {{- 'icon-account.svg' | inline_asset_content -}}
              </span>
              {% if customer.first_name != blank %}
                {{ customer.first_name }}
              {% elsif customer.email != blank %}
                {{ customer.email }}
              {% else %}
                {{ customer.phone }}
              {% endif %}
            </span>
          </li>
          <li class="account-actions__list-item">
            <a href="{{ routes.account_logout_url }}" class="account-actions__link account-actions__row">
              <span class="account-actions__icon" aria-hidden="true">
                {{- 'icon-account.svg' | inline_asset_content -}}
              </span>
              {{ 'actions.log_out' | t }}
            </a>
          </li>
        {% endif %}
        <li class="account-actions__list-item">
          <a href="{{ routes.account_url }}" class="account-actions__link account-actions__row">
            <span class="account-actions__icon" aria-hidden="true">
              {{- 'icon-orders.svg' | inline_asset_content -}}
            </span>
            {{ 'content.account_orders' | t }}
          </a>
        </li>
        <li class="account-actions__list-item">
          <a href="{{ routes.account_addresses_url }}" class="account-actions__link account-actions__row">
            <span class="account-actions__icon" aria-hidden="true">
              {{- 'icon-account.svg' | inline_asset_content -}}
            </span>
            {{ 'content.account_profile' | t }}
          </a>
        </li>
        <li class="account-actions__list-item">
          <a
            href="#st-wishlist-details-button"
            class="account-actions__link account-actions__row"
            title="{{ 'actions.wishlist' | t }}"
            aria-label="{{ 'actions.wishlist' | t }}"
          >
            <span class="account-actions__icon" aria-hidden="true">
              {{- 'icon-heart.svg' | inline_asset_content -}}
            </span>
            {{ 'actions.wishlist' | t }}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</div>

{% stylesheet %}
  .account-actions {
    background-color: var(--color-background);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: height var(--animation-values);

    &:has([data-active]) .account-actions__main-menu {
      visibility: hidden;
    }
  }

  .account-actions__row--identity {
    cursor: default;
  }

  .account-actions__sign-ins {
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .account-actions__sign-in-text {
    display: inline;
  }

  .account-actions__fallback-text {
    display: none;
  }

  .account-actions__sign-ins:not(:has(shop-login-button)) {
    gap: 0;

    .account-actions__sign-in-text {
      display: none;
    }

    .account-actions__fallback-text {
      display: block;
    }
  }

  /* Makes the shop login button radius match the theme settings */
  .account-actions__shop-login {
    --buttons-radius: var(--style-border-radius-buttons-primary);
  }

  /* Своя кнопка поверх, оригинал Shop Pay скрыт — клик делегируется в JS */
  .account-actions__sign-in-shop-wrap {
    position: relative;
  }
  .account-actions__sign-in-shop-wrap .account-actions__shop-login {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }
  .account-actions__sign-in-shop-wrap .account-actions__shop-login shop-login-button {
    width: 100%;
    height: 100%;
  }
  .account-actions__sign-in-shop-custom {
    position: relative;
    z-index: 1;
    width: 100%;
  }
  /* Если Shop Pay нет, скрыть обёртку с кастомной кнопкой (покажет только «Other sign in options») */
  .account-actions__sign-ins:not(:has(shop-login-button)) .account-actions__sign-in-shop-wrap {
    display: none;
  }

  .account-actions__nav {
    padding: 0;
    padding-block-start: 0;
  }

  .account-actions__list {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .account-actions__row,
  .account-actions__link.account-actions__row {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    width: 100%;
    padding: 0;
    text-align: start;
    text-decoration: none;
    color: inherit;
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
    font-size: 9.75pt;
    padding: 0.313rem 1.125rem;
  }

  .account-actions__link.account-actions__row:hover {
    color: var(--color-foreground);
  }

  .account-actions__link--primary.button {
    margin-block-end: var(--gap-sm);
  }

  .account-actions__icon {
    display: flex;
    flex-shrink: 0;
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
  }

  /* This triggers iOS < 16.4. The outline bug is not recognized as a lack of @supports */

  @supports not (background-color: rgb(from red 150 g b / alpha)) {
    /**
    There is a bug in safari < 16.4 that causes the outline to not follow the elements border radius. This is a workaround.
    Using element selector to increase specificity.
  **/

    .account-actions :is(a.button, a.button-secondary):focus-visible {
      outline: none;
      overflow: visible;
      position: relative;

      &::after {
        content: '';
        position: absolute;
        inset: calc(-1 * var(--focus-outline-offset));
        border: var(--focus-outline-width) solid currentColor;
        border-radius: var(--style-border-radius-buttons-secondary);
        display: inherit;
      }
    }

    .account-actions a.button:focus-visible::after {
      border-color: var(--button-background-color);
      border-radius: var(--style-border-radius-buttons-primary);
    }
  }
{% endstylesheet %}
