{% comment %}
  Renders Italy / UAE selector that redirects to the chosen storefront origin (same path).
  @param {object} block - section block (region_selector)
{% endcomment %}
{% liquid
  assign host_down = request.host | downcase
  assign italy_origin = block.settings.italy_store_url | strip
  assign uae_origin = block.settings.uae_store_url | strip
  if italy_origin == blank
    assign italy_origin = 'https://ludmillaradchenko.art'
  endif
  if uae_origin == blank
    assign uae_origin = 'https://uae.ludmillaradchenko.art'
  endif

  assign italy_host = italy_origin | replace: 'https://', '' | replace: 'http://', '' | split: '/' | first | downcase
  assign uae_host = uae_origin | replace: 'https://', '' | replace: 'http://', '' | split: '/' | first | downcase

  assign uae_www = 'www.' | append: uae_host
  assign italy_www = 'www.' | append: italy_host

  assign current_region = block.settings.fallback_region
  if host_down == uae_host or host_down == uae_www
    assign current_region = 'uae'
  elsif host_down == italy_host or host_down == italy_www
    assign current_region = 'italy'
  endif

  assign font_family = '--font-heading--family'
  case block.settings.font
    when 'subheading'
      assign font_family = '--font-subheading--family'
    when 'body'
      assign font_family = '--font-body--family'
    when 'accent'
      assign font_family = '--font-accent--family'
  endcase

  assign italy_label = block.settings.label_italy
  if italy_label == blank
    assign italy_label = 'Italy'
  endif
  assign uae_label = block.settings.label_uae
  if uae_label == blank
    assign uae_label = 'UAE'
  endif
%}

<div
  class="logo-and-customer__region"
  {{ block.shopify_attributes }}
>
  <label class="visually-hidden" for="LogoCustomerRegion-{{ block.id }}">
    {{- block.settings.accessibility_label | default: 'Store region' -}}
  </label>
  <select
    id="LogoCustomerRegion-{{ block.id }}"
    class="logo-and-customer-region__select"
    data-logo-customer-region-select
    data-design-mode="{% if request.design_mode %}true{% else %}false{% endif %}"
    data-current-value="{% if current_region == 'uae' %}{{ uae_origin }}{% else %}{{ italy_origin }}{% endif %}"
    style="--logo-customer-region-font-family: var({{ font_family }}); --logo-customer-region-font-size: {{ block.settings.font_size }};"
  >
    <option
      value="{{ italy_origin | escape }}"
      {% if current_region == 'italy' %}
        selected
      {% endif %}
    >
      🇮🇹 {{ italy_label }}
    </option>
    <option
      value="{{ uae_origin | escape }}"
      {% if current_region == 'uae' %}
        selected
      {% endif %}
    >
      🇦🇪 {{ uae_label }}
    </option>
  </select>
</div>
